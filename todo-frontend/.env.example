# Frontend build-time env (Vite inlines VITE_* at build).

# API base URL. Empty in dev (Vite proxies to the backend); set to your API
# origin in production if the frontend is served separately.
VITE_API_BASE_URL=

# Google OAuth client ID (same value as the backend GOOGLE_CLIENT_ID; public).
# BUILD-TIME: it is baked into the bundle by `bun run build`, so in CI it must be
# passed as a Docker --build-arg, not a Cloud Run runtime env var.
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
